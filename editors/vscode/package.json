{
  "name": "squint",
  "displayName": "squint SQL linter",
  "description": "Real-time SQL linting for dbt/Jinja SQL files via the squint LSP server",
  "version": "1.0.1",
  "publisher": "squint",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IlllIIIlllIlIlIIllllIIIlI/squint"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "sql",
    "dbt",
    "jinja",
    "linter"
  ],
  "activationEvents": [
    "onLanguage:sql",
    "onLanguage:mssql",
    "onLanguage:jinja-sql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "squint",
      "properties": {
        "squint.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the squint-lsp binary. Leave empty to use squint-lsp from PATH (or ~/.cargo/bin)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --minify",
    "compile": "tsc --noEmit",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
